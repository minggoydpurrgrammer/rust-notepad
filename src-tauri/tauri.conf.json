{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "rust-notepad",
  "version": "0.1.0",
  "identifier": "com.minggoy.rust-notepad",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Rust Notepad",
        "width": 1024,
        "height": 768,
        "resizable": true
      }
    ],
    "security": {
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  }
}